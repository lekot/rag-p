{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "RAG Platform Worker — job queue, throughput, success/failure, duration",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Jobs per Second",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ragp_worker_jobs_total{job=~\".*rag-p.*worker.*\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Success / Failure Ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ragp_worker_jobs_total{job=~\".*rag-p.*worker.*\", status=\"completed\"}[5m])) / sum(rate(ragp_worker_jobs_total{job=~\".*rag-p.*worker.*\"}[5m]))",
          "legendFormat": "success ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Job Duration p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ragp_worker_job_duration_seconds_bucket{job=~\".*rag-p.*worker.*\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ragp_worker_job_duration_seconds_bucket{job=~\".*rag-p.*worker.*\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis Queue Length (arq:default)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "redis_list_length{job=~\".*redis.*\", key=\"arq:queue:default\"}",
          "legendFormat": "queue depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Jobs (1h window)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(ragp_worker_jobs_total{job=~\".*rag-p.*worker.*\"}[1h]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Failed Jobs (1h window)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(ragp_worker_jobs_total{job=~\".*rag-p.*worker.*\", status=\"failed\"}[1h]))",
          "legendFormat": "failed",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["rag-p", "worker"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RAG Platform — Worker",
  "uid": "ragp-worker-v1",
  "version": 1
}
