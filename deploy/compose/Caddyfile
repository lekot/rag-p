{
	email {$CADDY_ACME_EMAIL}
}

lekottt.ru {
	encode zstd gzip
	reverse_proxy web:3000
}

www.lekottt.ru {
	redir https://lekottt.ru{uri} permanent
}

api.lekottt.ru {
	encode zstd gzip
	reverse_proxy api:8000 {
		# Preserve the originating client IP for the YooKassa webhook
		# allowlist check (apps/api/src/ragp_api/security/yookassa_webhook.py).
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
