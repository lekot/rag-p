POSTGRES_DB=ragp
POSTGRES_USER=ragp
POSTGRES_PASSWORD=change-me

RAGP_API_IMAGE=ghcr.io/lekot/rag-p-api:staging-latest
RAGP_WEB_IMAGE=ghcr.io/lekot/rag-p-web:staging-latest
NEXT_PUBLIC_API_URL=https://api.lekottt.ru
CADDY_ACME_EMAIL=ops@example.com
OLLAMA_MODEL=bge-m3

RAGP_SESSION_SECRET=change-me-48-random-bytes
RAGP_SECRET_KEY=change-me-48-random-bytes
RAGP_DEBUG=false
RAGP_ENFORCE_SUBSCRIPTION_QUOTAS=true
RAGP_LLM_FALLBACK_MODE=extractive

RAGP_YOOKASSA_SHOP_ID=
RAGP_YOOKASSA_SECRET_KEY=
RAGP_YOOKASSA_WEBHOOK_SECRET=
RAGP_YOOKASSA_RETURN_URL=https://lekottt.ru/account/billing
RAGP_YOOKASSA_TEST_MODE=false
RAGP_YOOKASSA_TAXATION_SYSTEM=6
RAGP_YOOKASSA_INN=

# Webhook security (IP allowlist + server-side re-validation).
# Defaults match the published YooKassa CIDRs (2026-04). Override via env if
# YooKassa publishes new ranges.
RAGP_YOOKASSA_ALLOWED_IPS=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.154.128/25,77.75.156.11/32,77.75.156.35/32,2a02:5180::/32
# Reverse proxies whose X-Forwarded-For we trust. Caddy on the Docker bridge
# uses 172.16.0.0/12; localhost covers single-host deployments.
RAGP_YOOKASSA_TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12,10.0.0.0/8
RAGP_YOOKASSA_REQUIRE_IP_CHECK=true
RAGP_YOOKASSA_REVALIDATE_PAYMENT=true
RAGP_YOOKASSA_REVALIDATE_TIMEOUT_SECONDS=10

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

RAGP_S3_ENDPOINT_URL=https://s3.ru-1.storage.selcloud.ru
RAGP_S3_REGION=ru-1
RAGP_S3_BUCKET=
RAGP_S3_ACCESS_KEY_ID=
RAGP_S3_SECRET_ACCESS_KEY=
RAGP_S3_SERVICE_USER=
RAGP_S3_SERVICE_PASSWORD=

# Postgres backup → Selectel S3. Use a dedicated bucket and access key
# distinct from the application document bucket above.
RAGP_PGBACKUP_S3_ENDPOINT_URL=https://s3.ru-1.storage.selcloud.ru
RAGP_PGBACKUP_S3_REGION=ru-1
RAGP_PGBACKUP_S3_BUCKET=rag-p-pg-backups
RAGP_PGBACKUP_S3_ACCESS_KEY_ID=
RAGP_PGBACKUP_S3_SECRET_ACCESS_KEY=
RAGP_PGBACKUP_PREFIX=pg-backups/
RAGP_PGBACKUP_HOUR_UTC=2
RAGP_PGBACKUP_MINUTE=15
RAGP_PGBACKUP_INTERVAL_HOURS=24
RAGP_PGBACKUP_RETENTION_DAYS=7
