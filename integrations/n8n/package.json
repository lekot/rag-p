{
  "name": "n8n-nodes-rag-p",
  "version": "0.1.1",
  "description": "n8n community node for RAG-Platform (rag-p) — query datasets, upload documents, and check dataset status from your workflows.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "rag",
    "rag-p",
    "rag-platform",
    "llm",
    "ai",
    "vector-search",
    "retrieval-augmented-generation"
  ],
  "license": "MIT",
  "homepage": "https://lekottt.ru",
  "author": {
    "name": "rag-p",
    "email": "support@lekottt.ru"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lekot/rag-p.git",
    "directory": "integrations/n8n"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-icons.js",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RagPApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RagP/RagP.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
